# Copy this file to .env and update values as needed.

# JSON Web Token secret (keep this safe)
JWT_SECRET=eventsphere_secret

# Admin registration secret (share only with admins)
ADMIN_SECRET=eventsphere_admin_secret

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/EventManagement

# Optional SMTP settings (if not provided, Ethereal test SMTP is used)
# For Gmail, use an App Password (https://myaccount.google.com/apppasswords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_SECURE=false

# Other providers (SendGrid, Mailgun, etc.) can work with the same fields.
# MAIL_FROM=no-reply@eventsphere.local

# Server port
PORT=5000
